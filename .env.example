# Ahwa configuration
#
# At least ONE LLM provider env var below must be set — Ahwa refuses to
# start a deliberation otherwise. Auto-detection priority when a council
# has no explicit model_config: Anthropic → OpenAI → OpenRouter → Ollama.

# Data directory (default: ./data)
AHWA_DATA_DIR=./data

# HTTP port (default: 3000 in production, 5173 in dev)
# PORT=3000

# Share-link signing secret. Generate with: openssl rand -hex 32
# If unset, a random secret is generated at startup (share links break
# across restarts — set this in production).
# AHWA_SHARE_SECRET=

# --- LLM Providers ---
# Uncomment and set one or more of the providers below:

# Anthropic (https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (https://platform.openai.com)
# OPENAI_API_KEY=sk-...

# OpenRouter (https://openrouter.ai — routes to many providers, includes free tier)
# OPENROUTER_API_KEY=sk-or-...

# Ollama (local models). Must be set explicitly — Ahwa no longer assumes
# a local daemon is reachable by default, since that silently fails on
# hosted deploys with no Ollama running.
# OLLAMA_BASE_URL=http://localhost:11434/api
