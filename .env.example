# Ahwa configuration
# At least one LLM provider must be configured, or Ollama must be running locally.
# Auto-detection priority: Anthropic → OpenAI → OpenRouter → Ollama

# Data directory (default: ./data)
AHWA_DATA_DIR=./data

# HTTP port (default: 3000 in production, 5173 in dev)
# PORT=3000

# --- LLM Providers ---
# Uncomment and set the providers you want to use:

# Anthropic (https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (https://platform.openai.com)
# OPENAI_API_KEY=sk-...

# OpenRouter (https://openrouter.ai — routes to many providers)
# OPENROUTER_API_KEY=sk-or-...

# Ollama (local models — no key needed, just the URL)
# OLLAMA_BASE_URL=http://localhost:11434/api
